  {
    "id": "ui.template.led",
    "type": "ui-template",
    "z": "flow.basic",
    "group": "ui.group.control",
    "page": "",
    "ui": "",
    "name": "LED visual",
    "order": 1,
    "width": 6,
    "height": 2,
    "head": "",
    "format": "<template>\n  <div class=\"led-box\">\n    <span class=\"led-dot\" :class=\"{ on: msg && msg.payload === true }\"></span>\n    <span>{{ msg && msg.payload === true ? 'LED ligado' : 'LED desligado' }}</span>\n  </div>\n</template>\n\n<style>\n.led-box {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  min-height: 48px;\n  font-size: 18px;\n}\n.led-dot {\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  background: #9ca3af;\n  border: 2px solid #6b7280;\n}\n.led-dot.on {\n  background: #22c55e;\n  border-color: #15803d;\n  box-shadow: 0 0 14px #22c55e;\n}\n</style>",
    "storeOutMessages": true,
    "passthru": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
