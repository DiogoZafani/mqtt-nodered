  {
    "id": "mqtt.in.telemetry",
    "type": "mqtt in",
    "z": "flow.basic",
    "name": "Receber dados",
    "topic": "iot/laboratorio/esp32-01/telemetry",
    "qos": "1",
    "datatype": "auto-detect",
    "broker": "mqtt.broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 140,
    "y": 120,
    "wires": [
      [
        "fn.process"
      ]
    ]
  },
  {
    "id": "fn.process",
    "type": "function",
    "z": "flow.basic",
    "name": "Verificar limites",
    "func": "let data = msg.payload;\n\nif (Buffer.isBuffer(data)) {\n    data = data.toString();\n}\n\nif (typeof data === 'string') {\n    data = JSON.parse(data);\n}\n\nconst tempAlta = data.temperature >= 27;\nconst umidadeAlta = data.humidity >= 70;\nconst avisos = [];\n\nif (tempAlta) {\n    avisos.push('Temperatura alta');\n}\n\nif (umidadeAlta) {\n    avisos.push('Umidade alta');\n}\n\nconst saidas = [\n    { payload: `${data.temperature} C` },\n    { payload: `${data.humidity}%` },\n    { payload: data.led },\n    null,\n    null\n];\n\nif (avisos.length > 0 && !context.get('ledTemporarioAtivo')) {\n    context.set('ledTemporarioAtivo', true);\n\n    saidas[2] = { payload: true };\n    saidas[3] = { payload: avisos.join(' e ') };\n    saidas[4] = {\n        topic: 'iot/laboratorio/esp32-01/cmd',\n        payload: JSON.stringify({ led: true }),\n        qos: 1,\n        retain: false\n    };\n\n    setTimeout(() => {\n        context.set('ledTemporarioAtivo', false);\n        node.send([\n            null,\n            null,\n            { payload: false },\n            { payload: '' },\n            {\n                topic: 'iot/laboratorio/esp32-01/cmd',\n                payload: JSON.stringify({ led: false }),\n                qos: 1,\n                retain: false\n            }\n        ]);\n    }, 3000);\n}\n\nreturn saidas;",
    "outputs": 5,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 120,
    "wires": [
      [
        "ui.text.temperature"
      ],
      [
        "ui.text.humidity"
      ],
      [
        "ui.template.led"
      ],
      [
        "ui.text.alert"
      ],
      [
        "mqtt.out.command"
      ]
    ]
  },
