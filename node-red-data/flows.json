  {
    "id": "ui.template.led",
    "type": "ui-template",
    "z": "flow.basic",
    "group": "ui.group.control",
    "page": "",
    "ui": "",
    "name": "LED visual",
    "order": 1,
    "width": 6,
    "height": 4,
    "head": "",
    "format": "<template>\n  <div class=\"lamp\" :class=\"{ on: msg && msg.payload === true }\">\n    <div class=\"rays\">\n      <span></span><span></span><span></span>\n    </div>\n    <div class=\"bulb\"></div>\n    <div class=\"neck\"></div>\n    <div class=\"base\"></div>\n  </div>\n</template>\n\n<style>\n.lamp {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-height: 130px;\n}\n.rays {\n  display: flex;\n  gap: 8px;\n  height: 18px;\n  align-items: end;\n  opacity: 0;\n}\n.rays span {\n  width: 5px;\n  height: 14px;\n  border-radius: 999px;\n  background: #facc15;\n}\n.rays span:first-child { transform: rotate(-28deg); }\n.rays span:last-child { transform: rotate(28deg); }\n.bulb {\n  width: 64px;\n  height: 64px;\n  border-radius: 50% 50% 42% 42%;\n  background: #9ca3af;\n  border: 3px solid #6b7280;\n}\n.neck {\n  width: 30px;\n  height: 14px;\n  background: #6b7280;\n  border-radius: 0 0 6px 6px;\n}\n.base {\n  width: 54px;\n  height: 12px;\n  background: #374151;\n  border-radius: 999px;\n}\n.lamp.on .rays { opacity: 1; }\n.lamp.on .bulb {\n  background: #fde047;\n  border-color: #ca8a04;\n  box-shadow: 0 0 26px #facc15;\n}\n</style>",
