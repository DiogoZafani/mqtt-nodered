    "id": "fn.manual.command",
    "type": "function",
    "z": "flow.basic",
    "name": "Comando manual",
    "func": "msg.topic = 'iot/laboratorio/esp32-01/cmd';\nmsg.payload = JSON.stringify({ led: msg.payload === true });\nmsg.qos = 1;\nmsg.retain = false;\nreturn msg;",
